    - Hamming distance
    - Jaro distance
    """
    print("\n" + "=" * 80)
    print("ASSIGNMENT 2: Edit Distance Sub-Methods")
    print("=" * 80)
    
    test_pairs = [
        ("kitten", "sitting"),
        ("Saturday", "Sunday"),
        ("Siddaramaiah", "Sidharamaiah"),
        ("Catherine", "Katherine"),
    ]
    
    print("\nComparing Edit Distance Algorithms:")
    print("-" * 80)
    print(f"{'Name 1':20} {'Name 2':20} {'Levenshtein':12} {'Damerau':12} {'Jaro':12}")
    print("-" * 80)
    
    for name1, name2 in test_pairs:
        lev = EditDistanceMethod.levenshtein_distance(name1, name2)
        dam = EditDistanceMethod.damerau_levenshtein_distance(name1, name2)
        jaro = EditDistanceMethod.jaro_similarity(name1, name2)
