def assignment_6_lemmatization_stemming():
    """
    Implement basic lemmatization and stemming concepts
    """
    print("\n" + "=" * 80)
    print("ASSIGNMENT 6: Lemmatization and Stemming")
    print("=" * 80)
    
    print("\nNote: Full NLTK implementation requires library installation")
    print("Demonstrating basic stemming logic:")
    print("-" * 80)
    
    def simple_stem(word: str) -> str:
        """Simple stemming by removing common suffixes"""
        suffixes = ['ing', 'ed', 'ly', 'es', 's', 'er', 'est']
        word_lower = word.lower()
        
        for suffix in suffixes:
            if word_lower.endswith(suffix) and len(word_lower) > len(suffix) + 2:
                return word_lower[:-len(suffix)]
        
        return word_lower
    
    test_words = [
        "running", "runner", "runs",
        "organization", "organizations",
        "similarity", "similar", "similarly"
    ]
    
    print(f"{'Original Word':20} {'Stemmed':20}")
    print("-" * 40)
    for word in test_words:
        stemmed = simple_stem(word)
        print(f"{word:20} {stemmed:20}")
    
    print("\n\nName Normalization (Similar to Lemmatization):")
    print("-" * 80)
    
    def normalize_name(name: str) -> str:
        """Normalize name by removing titles, punctuation, extra spaces"""
        # Remove common titles
        titles = ['mr', 'mrs', 'ms', 'dr', 'prof', 'sir', 'madam']
        name_lower = name.lower()
        
        for title in titles:
            name_lower = name_lower.replace(title + '.', '').replace(title, '')
        
        # Remove punctuation and extra spaces
        name_clean = ''.join(c if c.isalnum() or c.isspace() else ' ' for c in name_lower)
        name_clean = ' '.join(name_clean.split())
        
        return name_clean.title()
    
    test_names = [
        "Dr. John Smith",
        "Mrs. Catherine Jones",
        "Prof. Abdul Rasheed",
        "Mr.Nicholas-Brown"
    ]
    
    print(f"{'Original Name':30} {'Normalized Name':30}")
    print("-" * 60)
    for name in test_names:
        normalized = normalize_name(name)
        print(f"{name:30} {normalized:30}")


