def assignment_4_correlation_closeness():
    """
    Implement various methods to calculate correlation between input and output
    """
    print("\n" + "=" * 80)
    print("ASSIGNMENT 4: Calculating Correlation Closeness")
    print("=" * 80)
    
    test_cases = [
        ("Catherine", "Katherine"),
        ("Siddaramaiah", "Sidharamaiah"),
        ("Company Inc", "Corporation Incorporated"),
    ]
    
    stat = StatisticalMethod()
    
    print("\nMULTI-METHOD CORRELATION ANALYSIS:")
    print("-" * 80)
    
    for input_name, output_name in test_cases:
        
        print(f"\n{input_name} -> {output_name}")
        print("-" * 40)
        
        # Method 1: Edit Distance (normalized)
        lev_dist = EditDistanceMethod.levenshtein_distance(input_name, output_name)
        max_len = max(len(input_name), len(output_name))
        lev_similarity = 1 - (lev_dist / max_len) if max_len > 0 else 0
        print(f"1. Levenshtein Similarity: {lev_similarity:.3f}")
        
        # Method 2: Jaro-Winkler
        jaro_sim = EditDistanceMethod.jaro_winkler_similarity(input_name, output_name)
        print(f"2. Jaro-Winkler Similarity: {jaro_sim:.3f}")
        
        # Method 3: Phonetic Match
        soundex_match = 1.0 if CommonKeyMethod.soundex(input_name) == CommonKeyMethod.soundex(output_name) else 0.0
        print(f"3. Phonetic Match (Soundex): {soundex_match:.3f}")
        
        # Method 4: Combined Statistical Score
        combined_score = stat.calculate_similarity_score(input_name, output_name)
        print(f"4. Combined Statistical Score: {combined_score:.3f}")
        
        # Method 5: Accuracy Classification
        if combined_score >= 0.9:
            accuracy = "EXCELLENT"
        elif combined_score >= 0.8:
            accuracy = "VERY GOOD"
        elif combined_score >= 0.7:
            accuracy = "GOOD"
        elif combined_score >= 0.6:
            accuracy = "FAIR"
        else:
            accuracy = "POOR"
        
        print(f"5. Accuracy Rating: {accuracy}")


